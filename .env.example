# ── Daratech Bot — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.
# .env is gitignored and never pushed to GitHub.

# Your WhatsApp number (country code + number, no + or spaces)
OWNER_NUMBER=

# Session ID — base64-encoded creds.json.
# Leave blank on first run. After pairing, the bot writes it here automatically.
# Copy the value from .env into your panel/deployment environment variables
# so the session survives restarts without re-pairing.
SESSION_ID=
